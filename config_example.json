{
    "docs_dir": "./documents",
    "docs_lang": "en",
    "chunking": {
        "mode": "auto",
        "auto": {
            "target_chars": 700,
            "split_at_level": 3,
            "min_chars": 100,
            "include_heading": false
        },
        "fixed": {
            "split_by": "char",
            "char": {
                "max_chars": 700,
                "overlap_chars": 70
            },
            "line": {
                "max_lines": 20,
                "overlap_lines": 3
            }
        }
    },
    "embedding_model_name": {
        "zh": "BAAI/bge-small-zh-v1.5",
        "en": "mixedbread-ai/mxbai-embed-large-v1"
    },
    "chroma_persist_dir": "./chroma_db",
    "query_enhance_enabled": true,
    "vector_enabled": true,
    "bm25_enabled": true,
    "retrieval": {
        "mode": "llm",
        "k": 3,
        "distance_threshold": 0.3,
        "enhancer": {
            "local": {
                "query_lang": "zh",
                "model_name": "Helsinki-NLP/opus-mt-zh-en"
            },
            "llm": {
                "api_base_url": "https://api.deepseek.com",
                "api_key": "sk-your-api-key-here",
                "model": "deepseek-v4-flash",
                "temperature": 0.0,
                "thinking_mode": false
            }
        }
    },
    "reranker_enabled": false,
    "reranker": {
        "model_name": "BAAI/bge-reranker-v2-m3",
        "top_k": null
    },
    "llm": {
        "api_base_url": "https://api.deepseek.com",
        "api_key": "sk-your-api-key-here",
        "model": "deepseek-v4-flash",
        "temperature": 0.3,
        "thinking_mode": false
    },
    "max_history_rounds": 10,
    "debug": false,
    "strict_context": false
}